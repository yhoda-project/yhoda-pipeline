# Yorkshire Vitality Observatory — Environment Variable Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# PostgreSQL connection string (psycopg2 URL format)
# Example: postgresql+psycopg2://user:password@host:5432/dbname
DATABASE_URL=postgresql+psycopg2://user:password@host:5432/dbname

# ---------------------------------------------------------------------------
# API Keys
# ---------------------------------------------------------------------------
# NOMIS (ONS Labour Market Statistics API) — optional for public endpoints
NOMIS_API_KEY=

# DWP Stat-Xplore API key — required
DWP_API_KEY=your-dwp-api-key-here

# ---------------------------------------------------------------------------
# Prefect
# ---------------------------------------------------------------------------
# URL of your self-hosted Prefect server
PREFECT_API_URL=http://your-prefect-server:4200/api

# Work pool name (must exist on the Prefect server)
PREFECT_WORK_POOL=yhovi-default

# ---------------------------------------------------------------------------
# Alerts (optional)
# ---------------------------------------------------------------------------
# University of Sheffield email address used to send failure alerts
SMTP_USERNAME=your.email@sheffield.ac.uk

# Google App Password (generated at myaccount.google.com/apppasswords)
SMTP_PASSWORD=your-app-password-here

# Recipient address for pipeline alerts (single address or comma-separated list)
ALERT_GROUP_EMAIL=recipient@sheffield.ac.uk

# Set to true to receive an email on every successful flow run (default: false)
ALERT_SUCCESS_ENABLED=false

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
